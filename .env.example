PROJECTS_ROOT=projects
CHECKPOINT_DIR=.state/checkpoints
STORY_DB_FILENAME=story_bible.sqlite
CHROMA_DB_PATH=chroma_db
GENRE_PACK_DIR=genre_packs

OLLAMA_URL=http://127.0.0.1:11434/v1/chat/completions
OLLAMA_MODEL=phi3.5:3.8b-mini-instruct-q5_K_M
LOCAL_DISK_KV_URL=http://127.0.0.1:11434/v1/chat/completions
LOCAL_DISK_KV_MODEL=phi3.5:3.8b-mini-instruct-q5_K_M
EMBEDDING_MODEL=nomic-embed-text

HYPURA_URL=http://127.0.0.1:11435/api/chat
HYPURA_MODEL=mixtral-8x7b-instruct-turboquant
HYPURA_MODELS_DIR=/Volumes/256\ M.2/story-engine-models
HYPURA_PORT=11435

RAG_BUDGET_TOKENS=1700
SCENE_CHUNK_TOKENS=500
SCENE_CHUNK_OVERLAP=75

DEFAULT_GENRE_PACK=thriller_scifi
TARGET_MINUTES_MIN=14
TARGET_MINUTES_MAX=17
DEFAULT_WORDS_PER_MINUTE=150

LLM_CALL_TIMEOUT_SECONDS=300
LLM_MAX_RETRIES=2
LLM_RETRY_DELAY_SECONDS=2.0
LLM_THINKING_OVERHEAD=0
ALLOW_MODEL_FALLBACK=true
LLM_BACKEND=ollama
LLM_NUM_CTX=8192
USE_LOCAL_DISK_KV=false

REVIEWS_DIR=reviews
CHAPTER_COUNT=12
PAUSE_BEFORE_NARRATION_REVIEW=false
PAUSE_AFTER_CHAPTER_REVIEW=false

CHATTERBOX_URL=http://127.0.0.1:7865
CHATTERBOX_API=
VOICE_SAMPLE=
EXAGGERATION=0.4
CFG_WEIGHT=0.65
TEMPERATURE=0.72
SILENCE_PAD_MS=250
SILENCE_PAD=0.25
REQUEST_DELAY=0.5
MAX_RETRIES=2
RETRY_BACKOFF=0.75
TTS_SENTENCE_TIMEOUT_SECONDS=60
SAMPLE_RATE=22050
NARRATION_SPEED=1.0
MIN_PAUSE_END=0.24
MIN_PAUSE_MID=0.12
PAUSE_MULTIPLIER_END=1.0
PAUSE_MULTIPLIER_MID=0.7
PAUSE_PARAGRAPH_BONUS=0.15
INTRO_LEAD_IN_SECONDS=0.0
EXPORT_FORMATS=md
